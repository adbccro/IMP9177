{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "refresh": {
    "action": {
      "type": "Action.Execute",
      "verb": "gateStatus",
      "data": {
        "dcoId": "${dcoId}",
        "approverEmail": "${approverEmail}"
      }
    },
    "userIds": ["${approverEmail}"]
  },
  "body": [
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Document Change Order — Review required",
                  "size": "Small",
                  "color": "Accent",
                  "weight": "Bolder",
                  "spacing": "None"
                },
                {
                  "type": "TextBlock",
                  "text": "${dcoTitle}",
                  "size": "Large",
                  "weight": "Bolder",
                  "wrap": true,
                  "spacing": "Small"
                },
                {
                  "type": "TextBlock",
                  "text": "Submitted by ${originator} · Due ${dueDate}",
                  "size": "Small",
                  "isSubtle": true,
                  "spacing": "None"
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "${statusBadge}",
                  "color": "${statusColor}",
                  "weight": "Bolder",
                  "size": "Small"
                }
              ],
              "verticalContentAlignment": "Top"
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "spacing": "Medium",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Documents reviewed",
                  "size": "Small",
                  "isSubtle": true
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "${openedCount} of ${totalCount}",
                  "weight": "Bolder",
                  "color": "${progressColor}"
                }
              ]
            }
          ]
        },
        {
          "type": "TextBlock",
          "text": "${progressMessage}",
          "size": "Small",
          "isSubtle": true,
          "spacing": "None"
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "items": [
        {
          "$data": "${docs}",
          "type": "ColumnSet",
          "spacing": "Small",
          "separator": false,
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "verticalContentAlignment": "Center",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "${if(opened, '✅', '⬜')}",
                  "size": "Default"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "verticalContentAlignment": "Center",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "${docId}  ${docName}",
                  "wrap": false,
                  "isSubtle": "${opened}",
                  "weight": "${if(opened, 'Default', 'Bolder')}"
                },
                {
                  "type": "TextBlock",
                  "text": "${if(opened, openedAt, docType)}",
                  "size": "Small",
                  "isSubtle": true,
                  "spacing": "None"
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "verticalContentAlignment": "Center",
              "isVisible": "${not(opened)}",
              "items": [
                {
                  "type": "ActionSet",
                  "actions": [
                    {
                      "type": "Action.OpenUrl",
                      "title": "Open →",
                      "url": "${spUrl}",
                      "style": "positive"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "style": "emphasis",
      "spacing": "Medium",
      "items": [
        {
          "type": "TextBlock",
          "text": "Each document link is logged when accessed. This record satisfies 21 CFR Part 11 electronic review evidence requirements.",
          "size": "Small",
          "isSubtle": true,
          "wrap": true
        }
      ]
    },
    {
      "type": "Container",
      "isVisible": "${not(gateOpen)}",
      "items": [
        {
          "type": "TextBlock",
          "text": "⚠️  Open all ${remainingCount} remaining document(s) before approval unlocks.",
          "color": "Warning",
          "weight": "Bolder",
          "wrap": true,
          "spacing": "Medium"
        }
      ]
    },
    {
      "type": "Container",
      "isVisible": "${gateOpen}",
      "items": [
        {
          "type": "TextBlock",
          "text": "✅  All documents reviewed. Approval is ready.",
          "color": "Good",
          "weight": "Bolder",
          "spacing": "Medium"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Execute",
      "title": "Approve DCO",
      "verb": "approveDCO",
      "style": "positive",
      "isEnabled": "${gateOpen}",
      "tooltip": "${if(gateOpen, 'Approve this DCO', 'Open all documents first')}",
      "data": {
        "dcoId": "${dcoId}",
        "approverEmail": "${approverEmail}",
        "action": "approve"
      }
    },
    {
      "type": "Action.ShowCard",
      "title": "Reject",
      "card": {
        "type": "AdaptiveCard",
        "body": [
          {
            "type": "TextBlock",
            "text": "Rejection reason (required)",
            "weight": "Bolder"
          },
          {
            "type": "Input.Text",
            "id": "rejectionReason",
            "placeholder": "Enter reason for rejection...",
            "isMultiline": true
          }
        ],
        "actions": [
          {
            "type": "Action.Execute",
            "title": "Confirm rejection",
            "verb": "approveDCO",
            "style": "destructive",
            "data": {
              "dcoId": "${dcoId}",
              "approverEmail": "${approverEmail}",
              "action": "reject",
              "reason": "${rejectionReason}"
            }
          }
        ]
      }
    },
    {
      "type": "Action.OpenUrl",
      "title": "View in portal",
      "url": "https://adbccro.sharepoint.com/sites/IMP9177/SitePages/QMS-Portal.aspx"
    }
  ]
}
